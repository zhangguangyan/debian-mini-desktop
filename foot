[Desktop Entry]
Version=1.0
Type=Application
Name=Foot Tmux Maximized
Exec=foot --maximized sh -c 'tmux -q has-session && exec tmux attach-session -d || exec tmux new-session -s"$USER@$(hostname)" -n"$USER"'
Icon=utilities-terminal
Terminal=false
Categories=System;TerminalEmulator;
StartupNotify=true

systemctl --user disable --now foot-server.socket foot-server.service
